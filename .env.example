# Copy this to .env and fill in your values
# cp .env.example .env

# LiveKit API credentials — must match keys in livekit.yaml
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret000000000000000000000000

# LiveKit server WebSocket URL
# Local:      ws://localhost:7880
# Production: wss://your-domain.com  (after Nginx + SSL setup)
LIVEKIT_URL=ws://localhost:7880

# Signaling server port
PORT=3000
